# ══════════════════════════════════════════════════════════════════════════════
# Monitor do Diário Oficial de Mossoró — Exemplo de configuração
#
# INSTRUÇÕES:
#   1. Copie este arquivo:  cp .env.example .env
#   2. Substitua TODOS os valores de exemplo pelos seus dados reais
#   3. NUNCA faça commit do .env (já consta no .gitignore)
# ══════════════════════════════════════════════════════════════════════════════

# ── Nomes a monitorar [OBRIGATÓRIO] ──────────────────────────────────────────
# Separe múltiplos nomes por vírgula. Use MAIÚSCULAS.
# Inclua variantes com e sem acento para garantir detecção.
# Exemplo fictício — substitua pelos nomes reais que deseja monitorar.
NOMES_MONITORADOS=FULANO DE TAL,BELTRANA PEREIRA SOUZA,CICLANO ALVES DA SILVA

# ── Grupo do WhatsApp [OBRIGATÓRIO] ──────────────────────────────────────────
# Nome EXATO como aparece no WhatsApp (incluindo emoji se houver).
# Exemplo fictício — substitua pelo nome real do seu grupo.
WHATSAPP_GRUPO=Nome Exato Do Grupo WhatsApp

# ── Identificação da sala nas mensagens [OBRIGATÓRIO] ────────────────────────
# Texto exibido no cabeçalho das mensagens enviadas ao grupo.
# Exemplo fictício — substitua pela identificação real da sua sala/equipe.
NOME_SALA=Nome Da Sua Sala Aqui

# ── Horário de execução diária ────────────────────────────────────────────────
# Formato HH:MM — fuso America/Fortaleza (UTC-3)
# Diário Oficial costuma ser publicado madrugada/manhã; 05:00 garante captura.
HORARIO_EXECUCAO=05:00

# ── Timeout para escanear o QR code ──────────────────────────────────────────
# Segundos disponíveis para abrir o celular e escanear na 1ª execução.
# Aumente se precisar de mais tempo.
TIMEOUT_QR_CODE=120

# ── Controle de edições já monitoradas ───────────────────────────────────────
# Número da última edição do DOM processada com sucesso.
# O script atualiza este valor automaticamente após cada monitoramento.
# Defina como 0 para forçar o monitoramento na próxima execução.
ULTIMO_DOM_NUMERO=0

# ── Variáveis opcionais ───────────────────────────────────────────────────────

# Secretarias monitoradas para "Fofoca da Secretaria" (separadas por vírgula).
# Se omitido, usa a lista padrão de secretarias do município de Mossoró.
# SECRETARIAS_MOSSORO=SECRETARIA MUNICIPAL DE SAUDE,SECRETARIA MUNICIPAL DE EDUCACAO

# Caminho do perfil Chrome onde a sessão WhatsApp é salva.
# Se omitido, usa a pasta .whatsapp_profile ao lado do script.
# WHATSAPP_PROFILE_DIR=/caminho/para/perfil/chrome

# Pasta onde os arquivos de log são salvos.
# Se omitido, usa a mesma pasta do script.
# LOG_DIR=/caminho/para/logs

# Pasta onde os PDFs temporários fatiados são salvos antes do envio.
# Se omitido, usa a subpasta "pdfs_temporarios" ao lado do script.
# PDF_TEMP_DIR=/caminho/para/pdfs_temporarios
