# ══════════════════════════════════════════════════════════════════════════════
# Monitor do Diário Oficial de Mossoró — Configuração
#
# INSTRUÇÕES:
#   1. Copie este arquivo:  cp .env.example .env
#   2. Edite o .env com seus valores reais
#   3. NUNCA faça commit do .env (ele já está no .gitignore)
# ══════════════════════════════════════════════════════════════════════════════

# ── Nomes a monitorar ─────────────────────────────────────────────────────────
# Separe múltiplos nomes por vírgula. Use MAIÚSCULAS.
# Exemplos: "JOAO DA SILVA,MARIA SOUZA,ANA PEREIRA"
NOMES_MONITORADOS=JOSE LEOPOLDO DANTAS COUTO,CARLA VANNESSA DA ROCHA,MARIA LUCINEIDE VIDAL RODRIGUES

# ── Grupo do WhatsApp ─────────────────────────────────────────────────────────
# Nome EXATO como aparece no WhatsApp (incluindo emoji se houver)
WHATSAPP_GRUPO=Saúde | Educação PMM 💉🎓 - TESTES

# ── Horário de execução diária ────────────────────────────────────────────────
# Formato HH:MM — fuso America/Fortaleza (UTC-3)
# O monitor verifica o Diário Oficial do DIA ANTERIOR a este horário
HORARIO_EXECUCAO=07:30

# ── Timeout para escanear o QR code ──────────────────────────────────────────
# Segundos disponíveis para abrir o celular e escanear na 1ª execução
# Aumente se precisar de mais tempo
TIMEOUT_QR_CODE=120

# ── Senha do VNC ──────────────────────────────────────────────────────────────
# Usada para acessar o Chrome via http://localhost:7900 (interface noVNC)
# Necessário apenas para escanear o QR code do WhatsApp na primeira execução
VNC_PASSWORD=mossoro123
